# Default settings for httpd2.
# /etc/default/httpd2

# Options to pass to httpd2
HTTPD2_OPTS=\
  -k /etc/letsencrypt/config/live/carl.hoyer.ca/privkey.pem \
  -r /etc/letsencrypt/config/live/carl.hoyer.ca/fullchain.pem \
  -c -U 65534 -G 65534 \
  \
  -A [::]:443 \
  \
  --upgrade \
  --log-user-agent \
  --log-referer \
  --suppress-log-timestamps \
  --max-threads=10 \
  \
  /public/file/0
